<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700;900&family=Roboto:wght@400;700;900&display=swap" rel="stylesheet">

<style>
/* ── Reset & 基礎 ── */
.sx618, .sx618 *, .sx618 *::before, .sx618 *::after {
  box-sizing: border-box; margin: 0; padding: 0;
  font-family: 'Roboto', 'Noto Sans TC', sans-serif;
}

/* ── 全寬突破 Cyberbiz 容器限制 ── */
.sx618 {
  width: 100vw;
  position: relative;
  left: 50%;
  transform: translateX(-50%);

  --blue:       #0055b8;
  --blue-2:     #0066d6;
  --blue-dark:  #003d85;
  --blue-light: #e8f0fb;
  --blue-mid:   #ccddf5;
  --black:      #000000;
  --gray-1:     #f5f6f8;
  --gray-2:     #e8eaed;
  --gray-3:     #9EA0A0;
  --gray-4:     #666666;
  --white:      #ffffff;
  --gold:       #FFC300;
  --gold-dark:  #c07800;
  --orange:     #FF6B35;
  --wave-3-c:   #d4880a;
  --bg-main:    #09112f;
  --bg-stats:   #F6F6F6;
  --c-brand:    #05FFEA;
  --vw-drop:    3.33vw;

  background: var(--white);
  color: var(--black);
  line-height: 1.6;
  overflow-x: hidden;
}

/* ══════════════════════════════════════════════════════
   深色頂部背景（含 V 形切角）
══════════════════════════════════════════════════════ */
.sx618 .top-gradient-bg {
  background: var(--bg-main);
  clip-path: polygon(0 0, 100% 0, 100% 100%, 50% calc(100% - var(--vw-drop)), 0 100%);
  margin-bottom: calc(-1 * var(--vw-drop));
  position: relative;
  z-index: 1;
}

/* ══════════════════════════════════════════════════════
   倒數計時區塊
══════════════════════════════════════════════════════ */
.sx618 .hero-cd-block {
  text-align: center;
  padding: 40px 24px 60px;
}
.sx618 .cd-label-main {
  font-size: clamp(14px, 2.5vw, 18px);
  font-weight: 700;
  letter-spacing: 0.12em;
  color: rgba(255,255,255,0.85);
  margin-bottom: 12px;
  min-height: 1.5em;
  transition: color 0.4s;
}
.sx618 .cd-label-main.is-final { color: var(--orange); }

.sx618 .countdown {
  display: flex;
  justify-content: center;
  align-items: flex-start;
}
.sx618 .cd-unit {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.sx618 .cd-num {
  font-size: clamp(56px, 13vw, 116px);
  line-height: 1;
  color: var(--gold);
  min-width: clamp(60px, 13vw, 120px);
  text-align: center;
  letter-spacing: 0.02em;
  transition: color 0.4s;
}
.sx618 .cd-num.is-final { color: var(--orange); }
.sx618 .cd-label {
  font-size: 18px;
  letter-spacing: 0.14em;
  color: rgba(255,255,255,0.5);
  margin-top: 4px;
}
.sx618 .cd-sep {
  font-size: clamp(42px, 10vw, 92px);
  color: var(--gold);
  line-height: 1;
  padding: 0 2px;
  align-self: flex-start;
  margin-top: 6px;
  transition: color 0.4s;
}
.sx618 .cd-sep.is-final { color: var(--orange); }
.sx618 .cd-ended {
  display: none;
  font-size: 20px;
  font-weight: 700;
  color: rgba(255,255,255,0.65);
  padding: 32px 24px;
  letter-spacing: 0.08em;
}

/* ══════════════════════════════════════════════════════
   品牌列（深藍色 V 形）
══════════════════════════════════════════════════════ */
.sx618 .brand-section {
  background: #0D1020;
  clip-path: polygon(0 0, 100% 0, 100% 100%, 50% calc(100% - var(--vw-drop)), 0 100%);
  margin-bottom: calc(-1 * var(--vw-drop));
  position: relative;
  z-index: 2;
  padding-top: calc(24px + var(--vw-drop));
  padding-bottom: calc(32px + var(--vw-drop));
  text-align: center;
}
.sx618 .pchome-bar-title {
  font-size: clamp(24px, 5vw, 36px);
  font-weight: 900;
  color: var(--c-brand);
  letter-spacing: 0.06em;
  line-height: 1.2;
}
/* 修正：原版 clamp(45px, 3.5vw, 22px) min > max 的 Bug */
.sx618 .pchome-bar-sub {
  font-size: clamp(16px, 3.5vw, 22px);
  color: var(--white);
  font-weight: 700;
  letter-spacing: 0.16em;
  margin-top: 4px;
}

/* ══════════════════════════════════════════════════════
   統計數字列（淺灰底 V 形）
══════════════════════════════════════════════════════ */
.sx618 .stats-section {
  background: var(--bg-stats);
  clip-path: polygon(0 0, 100% 0, 100% calc(100% - var(--vw-drop)), 50% 100%, 0 calc(100% - var(--vw-drop)));
  margin-bottom: calc(-1 * var(--vw-drop));
  position: relative;
  z-index: 1;
  padding-top: calc(24px + var(--vw-drop));
  padding-bottom: calc(32px + var(--vw-drop));
}
.sx618 .stats-row {
  display: flex;
  justify-content: center;
  max-width: 1000px;
  margin: 0 auto;
}
.sx618 .stat-box {
  flex: 1;
  max-width: 33.333%;
  padding: 22px 0;
  text-align: center;
  position: relative;
  cursor: pointer;
}
.sx618 .stat-val,
.sx618 .stat-label {
  transition: transform 0.3s ease;
}
.sx618 .stat-box:hover .stat-val,
.sx618 .stat-box:hover .stat-label {
  transform: scale(1.08);
}
.sx618 .stat-box:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0; top: 50%;
  transform: translateY(-50%);
  width: 1px; height: 60px;
  background: rgba(0,0,0,0.2);
}
.sx618 .stat-val {
  font-weight: 900;
  line-height: 1;
  color: #1E90FF;
  letter-spacing: -0.05em;
  margin-bottom: 12px;
  display: flex;
  align-items: baseline;
  justify-content: center;
}
.sx618 .stat-val .sym  { font-size: clamp(48px, 10vw, 100px); }
.sx618 .stat-val .unit { font-size: clamp(28px, 5vw, 56px); margin: 0 2px; }
.sx618 .stat-label {
  font-size: clamp(14px, 3vw, 24px);
  font-weight: 900;
  letter-spacing: 0.1em;
  color: #000;
  display: block;
}

/* ══════════════════════════════════════════════════════
   品牌列（PChome 官方獨家）→ 取代原數據列文字
══════════════════════════════════════════════════════ */
.sx618 .stats-row--brand {
  justify-content: center;
  align-items: center;
}
.sx618 .stat-box--brand {
  max-width: 100%;
  padding: 16px 0;
  text-align: center;
  cursor: default;
}
.sx618 .stat-box--brand:hover .brand-title,
.sx618 .stat-box--brand:hover .brand-sub { transform: none; }
.sx618 .brand-title {
  font-size: clamp(36px, 7vw, 80px);
  font-weight: 900;
  color: #1E90FF;
  letter-spacing: 0.05em;
  line-height: 1.1;
}
.sx618 .brand-sub {
  font-size: clamp(16px, 3.5vw, 36px);
  font-weight: 700;
  color: #000;
  letter-spacing: 0.15em;
  margin-top: 6px;
}

/* ══════════════════════════════════════════════════════
   活動時程（階梯式時間軸）
══════════════════════════════════════════════════════ */
.sx618 .waves-section {
  background: transparent;
  padding: calc(80px + var(--vw-drop)) 5% 30px;
  position: relative;
  z-index: 1;
}
.sx618 .tl-title {
  text-align: center;
  font-size: clamp(28px, 5.5vw, 52px);
  font-weight: 900;
  color: var(--white);
  letter-spacing: 0.05em;
  margin-bottom: 8px;
}
.sx618 .tl-subtitle {
  text-align: center;
  font-size: clamp(13px, 2.8vw, 22px);
  font-weight: 700;
  color: var(--white);
  letter-spacing: 0.08em;
  margin-bottom: 72px;
}
.sx618 .tl-stagger-container {
  position: relative;
  max-width: 1000px;
  width: 90%;
  margin: 0 auto;
  height: calc(var(--vw-drop) + clamp(72px, 12vw, 134px));
}
.sx618 .tl-stagger-col {
  position: absolute;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80px;
  z-index: 2;
}
.sx618 .tl-date {
  font-weight: 900;
  font-size: clamp(18px, 4.5vw, 56px);
  color: var(--white);
  line-height: 1;
  margin-bottom: 12px;
  text-shadow: 0 2px 4px rgba(0,0,0,0.25);
  white-space: nowrap;
}
.sx618 .tl-line {
  width: 1px;
  height: clamp(40px, 8vw, 80px);
  background: rgba(255,255,255,0.8);
}
.sx618 .tl-stagger-wave {
  position: absolute;
  transform: translate(-50%, -50%);
  margin-top: calc(12px + clamp(40px, 8vw, 82px));
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
}
.sx618 .tl-wnum {
  font-size: clamp(14px, 3.5vw, 32px);
  font-weight: 900;
  color: var(--white);
  text-shadow: 0 2px 4px rgba(0,0,0,0.25);
}

/* ══════════════════════════════════════════════════════
   波次明細（淺灰底，垂直線 + 商品數）
══════════════════════════════════════════════════════ */
.sx618 .wave-details-section {
  background: var(--bg-stats);
  position: relative;
  z-index: 0;
  padding-top: calc(16px + var(--vw-drop));
  padding-bottom: 24px;
}
.sx618 .tl-details-container {
  position: relative;
  max-width: 1000px;
  width: 90%;
  margin: 0 auto;
  height: clamp(70px, 9vw, 110px);
}
.sx618 .tl-gray-line {
  position: absolute;
  top: 0; bottom: 0;
  width: 1px;
  background: #A0A0A0;
  transform: translateX(-50%);
}
.sx618 .tl-details-content {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 50%;
  text-align: center;
  padding: 0 10px;
}
.sx618 .tl-details-text {
  font-size: clamp(14px, 2.5vw, 24px);
  font-weight: 900;
  color: var(--black);
}
.sx618 .tl-new-badge {
  display: inline-block;
  font-size: clamp(11px, 1.8vw, 14px);
  background: var(--gold);
  color: #111;
  padding: 4px 10px;
  border-radius: 20px;
  margin-top: 8px;
  font-weight: 700;
  letter-spacing: 0.04em;
}

/* ══════════════════════════════════════════════════════
   活動介紹
══════════════════════════════════════════════════════ */
.sx618 .intro-section {
  padding: 80px 5% 64px;
  background: var(--white);
}
.sx618 .intro-title {
  text-align: center;
  font-size: clamp(20px, 4vw, 32px);
  font-weight: 900;
  color: var(--black);
  letter-spacing: 0.1em;
  margin-bottom: 32px;
}
.sx618 .intro-list { max-width: 800px; margin: 0 auto; }
.sx618 .intro-item {
  font-size: clamp(13px, 1.8vw, 16px);
  color: var(--gray-4);
  line-height: 1.9;
  padding: 16px 0;
  border-bottom: 1px solid var(--gray-2);
  text-align: center;
  letter-spacing: 0.03em;
}
.sx618 .intro-item:first-child { border-top: 1px solid var(--gray-2); }
.sx618 .intro-item:last-child  { border-bottom: none; }
.sx618 .intro-item strong { color: var(--blue); font-weight: 700; }

/* ══════════════════════════════════════════════════════
   CTA 按鈕
══════════════════════════════════════════════════════ */
.sx618 .cta-section {
  padding: 40px 24px 64px;
  text-align: center;
  background: var(--white);
  border: none;
}
.sx618 .cta-title {
  font-size: clamp(18px, 4vw, 28px);
  font-weight: 900;
  color: var(--black);
  letter-spacing: 0.1em;
  margin-bottom: 20px;
}
.sx618 .cta-arrow-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: clamp(72px, 10vw, 96px);
  height: clamp(40px, 5vw, 54px);
  background: var(--blue);
  border: none;
  border-radius: 4px;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}
.sx618 .cta-arrow-btn:hover { background: var(--blue-2); transform: translateY(2px); }
.sx618 .cta-arrow-btn::before {
  content: '';
  display: block;
  width: 14px; height: 14px;
  border-right: 3px solid #fff;
  border-bottom: 3px solid #fff;
  transform: rotate(45deg) translate(-2px, -2px);
}

/* ══════════════════════════════════════════════════════
   商品列表
══════════════════════════════════════════════════════ */
.sx618 .products-section { background: var(--gray-1); padding: 64px 5% 80px; }
.sx618 .products-section .section-title {
  color: var(--black); margin-bottom: 32px;
  font-size: clamp(20px, 4vw, 36px); font-weight: 900; text-align: center;
}

.sx618 .filter-bar {
  display: flex; gap: 8px; flex-wrap: wrap;
  justify-content: center; margin-bottom: 16px;
}
.sx618 .fil-btn {
  font-size: clamp(12px, 1.8vw, 15px); letter-spacing: 0.06em;
  padding: 8px 16px; border-radius: 20px;
  border: 1px solid var(--gray-2); background: var(--white);
  color: var(--gray-4); cursor: pointer; transition: all 0.15s;
}
.sx618 .fil-btn:hover { border-color: var(--blue); color: var(--blue); }
.sx618 .fil-btn.active { background: var(--black); border-color: var(--black); color: #fff; }

.sx618 .sort-bar {
  display: flex; align-items: center; gap: 8px;
  justify-content: center; margin-bottom: 32px; flex-wrap: wrap;
}
.sx618 .sort-label {
  font-size: clamp(11px, 1.8vw, 14px); color: var(--gray-3);
  letter-spacing: 0.1em; margin-right: 4px;
}
.sx618 .sort-btn {
  font-size: clamp(11px, 1.8vw, 14px); padding: 6px 14px;
  border-radius: 20px; border: 1px solid var(--gray-2);
  background: var(--white); color: var(--gray-4);
  cursor: pointer; transition: all 0.15s;
}
.sx618 .sort-btn:hover { border-color: var(--blue); color: var(--blue); }
.sx618 .sort-btn.active { background: var(--black); border-color: var(--black); color: var(--white); }

.sx618 .prod-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1px; max-width: 1200px; margin: 0 auto;
  background: var(--gray-2); border: 1px solid var(--gray-2);
}
.sx618 .prod-card {
  background: var(--white); display: flex; flex-direction: column;
  transition: box-shadow 0.2s, transform 0.2s; overflow: hidden;
}
.sx618 .prod-card:hover {
  box-shadow: 0 4px 24px rgba(0,85,184,0.1); transform: translateY(-2px);
  z-index: 1; position: relative; background: var(--blue-light);
}
.sx618 .prod-card.hidden { display: none; }
.sx618 .prod-img-wrap {
  aspect-ratio: 1 / 1; background: var(--gray-1);
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
.sx618 .prod-img-wrap img {
  width: 75%; height: 75%; object-fit: contain; transition: transform 0.3s;
}
.sx618 .prod-card:hover .prod-img-wrap img { transform: scale(1.05); }
.sx618 .prod-flag {
  position: absolute; top: 12px; left: 0;
  background: var(--blue); color: var(--white);
  font-size: 15px; font-weight: 700; letter-spacing: 0.06em;
  padding: 3px 10px 3px 8px;
  clip-path: polygon(0 0, 100% 0, 95% 50%, 100% 100%, 0 100%);
}
.sx618 .prod-flag.coming {
  background: var(--wave-3-c); clip-path: none;
  border-radius: 0 2px 2px 0; color: #000;
}
.sx618 .prod-body {
  padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 10px;
}
.sx618 .prod-name    { font-size: 22px; font-weight: 700; color: var(--black); }
.sx618 .prod-subtitle { font-size: 14px; color: var(--gray-4); line-height: 1.3; }
.sx618 .prod-prices  { display: flex; flex-direction: column; gap: 4px; }
.sx618 .prod-orig    { font-size: 12px; color: var(--gray-3); text-decoration: line-through; }
.sx618 .prod-disc    { font-size: 13px; font-weight: 500; color: var(--gray-4); }
.sx618 .prod-save    { font-size: 14px; font-weight: 700; color: var(--gold-dark); }
.sx618 .prod-final   { font-size: 38px; font-weight: 900; line-height: 1; color: var(--blue); }
.sx618 .prod-final-currency { font-size: 26px; font-weight: 700; }
.sx618 .prod-warranty {
  font-size: 11px; color: var(--gray-3); letter-spacing: 0.04em;
  padding-top: 10px; border-top: 1px solid var(--gray-2);
}
.sx618 .prod-btn {
  display: block; background: transparent;
  border: 1px solid var(--blue); color: var(--blue);
  font-size: 14px; font-weight: 700; letter-spacing: 0.1em;
  text-align: center; padding: 14px; text-decoration: none;
  text-transform: uppercase; cursor: pointer; transition: all 0.15s;
  border-radius: 1px; margin-top: auto;
}
.sx618 .prod-btn:hover { background: var(--blue); color: var(--white); }
.sx618 .prod-card.coming-soon .prod-img-wrap { opacity: 0.55; }
.sx618 .prod-card.coming-soon { order: 999; }
.sx618 .prod-btn.coming { border-color: var(--wave-3-c); color: var(--wave-3-c); cursor: default; }
.sx618 .prod-btn.coming:hover { background: rgba(212,136,10,0.06); color: var(--wave-3-c); }

/* ══════════════════════════════════════════════════════
   頁尾
══════════════════════════════════════════════════════ */
.sx618 .footer { background: var(--gray-1); padding: 40px 24px 32px; }
.sx618 .footer-inner { max-width: 1200px; margin: 0 auto; }
.sx618 .footer-bottom {
  display: flex; align-items: center;
  justify-content: space-between;
  flex-wrap: wrap; gap: 12px;
  padding-top: 0; border-top: none;
}
.sx618 .footer-copy { font-size: 12px; color: var(--gray-4); letter-spacing: 0.06em; }
.sx618 .footer-link {
  font-size: 12px; color: var(--blue); text-decoration: none;
  letter-spacing: 0.08em; border-bottom: 1px solid var(--blue-mid);
  padding-bottom: 1px; transition: color 0.15s;
}
.sx618 .footer-link:hover { color: var(--blue-dark); }

/* ══════════════════════════════════════════════════════
   手機版垂直時間軸（預設隱藏，480px 以下才顯示）
══════════════════════════════════════════════════════ */
.sx618 .mobile-vtl-section { display: none; }

/* ══════════════════════════════════════════════════════
   RWD — 平板 (≤ 768px)
══════════════════════════════════════════════════════ */
@media (max-width: 768px) {
  .sx618 .prod-grid { grid-template-columns: repeat(2, 1fr); }
  .sx618 .footer-bottom { flex-direction: column; align-items: flex-start; }
  .sx618 .waves-section { padding-top: calc(64px + var(--vw-drop)); }
  .sx618 .fil-btn  { padding: 7px 13px; }
  .sx618 .sort-btn { padding: 5px 11px; }
}

/* ══════════════════════════════════════════════════════
   RWD — 手機 (≤ 480px)
══════════════════════════════════════════════════════ */
@media (max-width: 480px) {

  /* ── 隱藏電腦版時間軸，顯示手機版垂直時間軸 ── */
  .sx618 .waves-section,
  .sx618 .wave-details-section { display: none !important; }

  /* ── 手機版垂直時間軸：新版型 ── */
  .sx618 .mobile-vtl-section {
    display: block;
    background: #09112f;
    padding: 48px 0 48px;
  }
  .sx618 .mvtl-header {
    padding: 0 10% 36px;
  }
  .sx618 .mobile-vtl-section .tl-title {
    font-size: clamp(30px, 9vw, 46px);
    font-weight: 900;
    color: #fff;
    letter-spacing: 0.03em;
    margin-bottom: 8px;
  }
  .sx618 .mobile-vtl-section .tl-subtitle {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.04em;
  }

  /* 整體容器：左右留白 */
  .sx618 .mvtl-wrap {
    width: 74%;
    margin: 0 5% 0 21%;
  }

  /* 每個波次區塊 */
  .sx618 .mvtl-item {
    background: #09112f;
  }
  .sx618 .mvtl-item--end {
    border: none;
  }

  /* 日期行：日期金色大字 + 橫線 */
  .sx618 .mvtl-date-row {
    display: flex;
    align-items: center;
    padding: 12px 0 0 0;
    gap: 0;
  }
  .sx618 .mvtl-date {
    font-size: clamp(26px, 8.5vw, 40px);
    font-weight: 900;
    color: #d4a843;
    letter-spacing: 0.04em;
    white-space: nowrap;
    flex-shrink: 0;
    padding-right: 16px;
  }
  .sx618 .mvtl-hline {
    flex: 1;
    height: 1.5px;
    background: rgba(255,255,255,0.25);
    display: block;
  }

  /* 波次行：縮排，第X波金色 + badge 空心邊框 */
  .sx618 .mvtl-wave-row {
    display: flex;
