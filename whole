<!-- ════════════════════════════════════════════════════════════
     SpearX × PChome 618 折扣戰  ·  JavaScript 檔
     修改說明：
       · 活動波次日期  → 修改 WAVES 陣列內的 start 時間
       · 活動結束時間  → 修改 EVENT_END
       · Wave 3 解鎖時間（來不及商品）→ WAVES[2].start 自動同步
     ════════════════════════════════════════════════════════════ -->
<script>
(function () {

  /* ── 活動波次設定 ── */
  var WAVES = [
    { start: new Date('2026-05-25T11:00:00+08:00'), name: '第一波' },
    { start: new Date('2026-06-01T11:00:00+08:00'), name: '第二波' },
    { start: new Date('2026-06-08T11:00:00+08:00'), name: '第三波' },
    { start: new Date('2026-06-15T11:00:00+08:00'), name: '第四波' }
  ];
  var EVENT_END   = new Date('2026-06-22T10:59:00+08:00');
  var WAVE3_START = WAVES[2].start; /* coming-soon 商品解鎖時間 */

  /* ── 判斷目前處於哪個階段 ── */
  function getPhase(now) {
    if (now < WAVES[0].start) {
      return {
        state: 'before',
        label: '距 第一波 開跑',
        countdownTo: WAVES[0].start,
        isFinal: false
      };
    }
    if (now >= EVENT_END) {
      return { state: 'ended' };
    }
    for (var i = 0; i < WAVES.length; i++) {
      var wEnd = (i < WAVES.length - 1) ? WAVES[i + 1].start : EVENT_END;
      if (now >= WAVES[i].start && now < wEnd) {
        var isFinal = (i === WAVES.length - 1);
        return {
          state: 'running',
          isFinal: isFinal,
          countdownTo: isFinal ? EVENT_END : WAVES[i + 1].start,
          label: isFinal
            ? '🔥 最後一波！活動截止倒數'
            : ('第' + (i + 1) + '波進行中 · 距 第' + (i + 2) + '波 開跑')
        };
      }
    }
    return { state: 'ended' };
  }

  function pad(n) { return String(n).padStart(2, '0'); }

  /* ── 更新倒數顯示（每秒呼叫）── */
  function updateCountdown() {
    var now   = new Date();
    var phase = getPhase(now);
    var label  = document.getElementById('sx-cd-label');
    var cdWrap = document.getElementById('sx-countdown');
    var ended  = document.getElementById('sx-ended');

    if (phase.state === 'ended') {
      if (cdWrap) cdWrap.style.display = 'none';
      if (label)  label.style.display  = 'none';
      if (ended)  ended.style.display  = 'block';
      return;
    }

    if (label) {
      label.textContent = phase.label;
      label.classList.toggle('is-final', phase.isFinal);
    }
    document.querySelectorAll('.sx618 .cd-num, .sx618 .cd-sep').forEach(function (el) {
      el.classList.toggle('is-final', phase.isFinal);
    });

    var diff = Math.max(0, phase.countdownTo - now);
    var d = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000)  / 60000);
    var s = Math.floor((diff % 60000)    / 1000);

    document.getElementById('sx-cd-d').textContent = d;
    document.getElementById('sx-cd-h').textContent = pad(h);
    document.getElementById('sx-cd-m').textContent = pad(m);
    document.getElementById('sx-cd-s').textContent = pad(s);
  }

  /* ── 第3波商品解鎖（6/8 11:00 自動切換）── */
  function checkWave3() {
    var isOpen = new Date() >= WAVE3_START;
    document.querySelectorAll('.sx618 .prod-card[data-coming="1"]').forEach(function (card) {
      var flag    = card.querySelector('.prod-flag');
      var btn     = card.querySelector('.prod-btn');
      var imgWrap = card.querySelector('.prod-img-wrap');
      var disc    = card.dataset.discount;
      if (isOpen) {
        card.classList.remove('coming-soon');
        card.style.order    = '';
        card.dataset.coming = '0';
        if (flag)    { flag.classList.remove('coming'); flag.textContent = '折 ' + disc + '%'; }
        if (imgWrap) imgWrap.style.opacity = '1';
        if (btn)     { btn.classList.remove('coming'); btn.textContent = '前往 PChome 購買'; }
      } else {
        card.classList.add('coming-soon');
        card.style.order = '999';
        if (flag)    { flag.classList.add('coming'); flag.textContent = '6/8 折扣開跑'; }
        if (imgWrap) imgWrap.style.opacity = '0.55';
        if (btn)     { btn.classList.add('coming'); btn.textContent = '🔔 6/8 折扣開跑'; }
      }
    });
  }

  /* ── CTA 按鈕：展開商品區 ── */
  window.sxShowProducts = function () {
    var section = document.getElementById('sx-products');
    var cta     = document.getElementById('sx-cta');
    if (section) {
      section.style.display = 'block';
      setTimeout(function () {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 50);
    }
    if (cta) cta.style.display = 'none';
  };

  /* ── 篩選 ── */
  window.sxFilter = function (tag, el) {
    document.querySelectorAll('.sx618 .fil-btn').forEach(function (b) { b.classList.remove('active'); });
    el.classList.add('active');
    document.querySelectorAll('.sx618 .prod-card').forEach(function (card) {
      if (tag === 'all') { card.classList.remove('hidden'); return; }
      card.classList.toggle('hidden', card.dataset.tags.split(',').indexOf(tag) === -1);
    });
  };

  /* ── 排序 ── */
  window.sxSort = function (rule, el) {
    document.querySelectorAll('.sx618 .sort-btn').forEach(function (b) { b.classList.remove('active'); });
    el.classList.add('active');
    var grid  = document.getElementById('sx-prod-grid');
    var cards = Array.from(grid.querySelectorAll('.prod-card'));
    cards.sort(function (a, b) {
      /* coming-soon 商品永遠排最後 */
      var aC = +a.dataset.coming, bC = +b.dataset.coming;
      if (aC !== bC) return aC - bC;
      if (rule === 'default') return 0;
      var aP = +a.dataset.price,    bP = +b.dataset.price;
      var aD = +a.dataset.discount, bD = +b.dataset.discount;
      if (rule === 'price-asc')     return aP - bP;
      if (rule === 'price-desc')    return bP - aP;
      if (rule === 'discount-desc') return bD - aD;
      return 0;
    });
    cards.forEach(function (card) { grid.appendChild(card); });
  };

  /* ── 啟動 ── */
  updateCountdown();
  checkWave3();
  setInterval(updateCountdown, 1000);
  setInterval(checkWave3, 60000);

  /* ── 手機版垂直時間軸：波次按鈕 toggle ── */
  window.mvtlToggle = function(btn) {
    var wave = btn.getAttribute('data-wave');
    var detail = document.getElementById('mvtl-detail-' + wave);
    var isOpen = btn.classList.contains('active');

    // 關閉所有已開啟的
    document.querySelectorAll('.mvtl-btn.active').forEach(function(b) {
      b.classList.remove('active');
    });
    document.querySelectorAll('.mvtl-detail.open').forEach(function(d) {
      d.classList.remove('open');
    });

    // 若原本是關閉的，才打開
    if (!isOpen && detail) {
      btn.classList.add('active');
      detail.classList.add('open');
    }
  };

})();
</script>
